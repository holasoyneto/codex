{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CODEX",
  "version": "0.1.0",
  "identifier": "app.codex.bible",

  "build": {
    "frontendDist": "../",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "node ../server.js",
    "beforeBuildCommand": ""
  },

  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CODEX",
        "width": 1400,
        "height": 900,
        "minWidth": 320,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "fullscreen": false,
        "center": true,
        "fileDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: https://asset.localhost; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: asset: https://asset.localhost; connect-src 'self' http://localhost:3000 http://127.0.0.1:3000 https://bible-api.com https://api.anthropic.com https://api.x.ai https://*.tile.openstreetmap.org"
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "CODEX"
    }
  },

  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "Education",
    "shortDescription": "Distraction-respectful Bible study",
    "longDescription": "CODEX is a distraction-respectful Bible study environment that fuses classical scripture with modern AI lenses — Strong's, cross-references, parsha, timeline, Oracle chat, study plans, and more.",
    "resources": [
      "../server.js",
      "../index.html",
      "../styles.css",
      "../*.js",
      "../*.jsx",
      "../data/**/*",
      "../screens/**/*"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": true,
        "files": {}
      },
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "nodejs"],
        "section": "education",
        "priority": "optional"
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3", "nodejs"]
      }
    },
    "fileAssociations": [
      {
        "ext": ["codex-study"],
        "name": "CODEX Study",
        "description": "CODEX sermon / study notebook",
        "role": "Editor",
        "mimeType": "application/x-codex-study"
      },
      {
        "ext": ["codex-module"],
        "name": "CODEX Module",
        "description": "CODEX pluggable study module",
        "role": "Viewer",
        "mimeType": "application/x-codex-module"
      }
    ]
  },

  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://releases.codex.app/{{target}}/{{current_version}}"
      ],
      "dialog": true,
      "pubkey": "REPLACE_WITH_GENERATED_TAURI_UPDATER_PUBKEY_BASE64"
    },
    "shell": {
      "open": "^https?://",
      "scope": [
        { "name": "node", "cmd": "node", "args": true, "sidecar": false }
      ]
    },
    "global-shortcut": {
      "all": true
    }
  }
}
