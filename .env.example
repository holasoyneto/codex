# Copy this file to .env and fill in one or more provider keys.
# After saving, restart the server:  node server.js
# The .env file is gitignored — never commit keys.

# ─── AI providers (set any combination) ───────────────────────────────
# Anthropic Claude  (paid)   https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE-ME

# xAI Grok          (paid)   https://console.x.ai
# XAI_API_KEY=xai-REPLACE-ME

# Groq              (free)   https://console.groq.com — runs Llama / DeepSeek / Qwen
# NOTE: Groq (groq.com) is DIFFERENT from xAI's Grok above.
# GROQ_API_KEY=gsk_REPLACE_ME

# Google Gemini     (free)   https://aistudio.google.com/apikey
# 1M tokens/day, ~15 req/min free tier. Keys usually start with "AIza".
# GEMINI_API_KEY=AIzaREPLACE_ME

# Ollama            (local)  https://ollama.com — runs models on your own machine.
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Optional: pin a specific Anthropic model. Defaults to Haiku 4.5.
# CODEX_MODEL=claude-sonnet-4-6

# BTC donation pool — receive on-chain BTC, issue free Haiku quota.
# Set this to YOUR BTC address. Mainnet by default.
# $1 USD of BTC = 250,000 Haiku tokens, drawn from the server's pool key.
DONATION_BTC_ADDRESS=bc1qREPLACE-WITH-YOUR-BTC-ADDRESS

# Optional: flip to "1" to verify against blockstream.info testnet for smoke
# testing (faucets at https://coinfaucet.eu/en/btc-testnet/). Default mainnet.
# CODEX_BTC_TESTNET=0
