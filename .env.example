# Copy this file to .env and fill in your Anthropic API key.
# Get one at https://console.anthropic.com/settings/keys
#
# After saving, restart the server:
#   node server.js
#
# The .env file is gitignored — never commit your key.

ANTHROPIC_API_KEY=sk-ant-api03-REPLACE-ME

# Optional: pin a specific model. Defaults to Haiku 4.5.
# CODEX_MODEL=claude-sonnet-4-6
